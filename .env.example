# data-pipeline 环境变量示例
# 与 caishui-webapp 共享同一 PostgreSQL 实例
DATABASE_URL=postgresql+asyncpg://caishui:localdev_password@localhost:5432/caishui_db
# 仅接受由 WebApp 使用此密钥签发的短时效请求；与 WebApp 配置完全一致。
PIPELINE_SHARED_SECRET=

# DeepSeek（仅 Chat / 生成）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embedding 提供商（独立，见 ADR-0006）：硅基流动 + BAAI/bge-large-zh-v1.5（1024维）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# 本地文件存储目录（未来可替换为腾讯云 COS）
STORAGE_DIR=./_storage
